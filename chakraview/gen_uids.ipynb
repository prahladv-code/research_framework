   "source": [
    "def gen_uids(strat: str, underlying: str, params: list):\n",
    "\n",
    "    uid_initials = f'{strat}_{underlying}'\n",
    "    uid = f\"{uid_initials}_{'_'.join(map(str, params))}\"\n",
    "\n",
    "    return uid\n",
    "\n",
    "uid1 = gen_uids('ORBSTOCKS', 'NIFTY', ['5', '2', '15', 'False'])\n",
    "uid1"
   ]
